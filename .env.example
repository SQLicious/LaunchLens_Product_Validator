# ---- LLM (the agent brain) ----
# Default provider is Qwen cloud (Alibaba DashScope). You need ONE working LLM key.
#
# Qwen cloud (DashScope) — OpenAI-compatible endpoint, supports tool calling.
# Get a key: https://dashscope.console.aliyun.com/  (or the international console).
LLM_PROVIDER=qwen
LLM_MODEL=qwen-plus                 # e.g. qwen-plus, qwen-max, qwen-turbo
QWEN_API_KEY=sk-your-dashscope-key
# Intl endpoint (default). For mainland-China accounts use:
#   https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Alternative provider: OpenAI (set LLM_PROVIDER=openai and LLM_MODEL=gpt-4o-mini)
# OPENAI_API_KEY=sk-your-openai-key

# ---- Demand data: SerpApi (free tier ~250 searches/month) ----
# https://serpapi.com/  -> Dashboard -> Your Private API Key
SERPAPI_API_KEY=your-serpapi-key

# ---- Supply data: Oxylabs Amazon Scraper API ----
OXYLABS_USERNAME=your-oxylabs-username
OXYLABS_PASSWORD=your-oxylabs-password

# ---- Behaviour ----
# MOCK_MODE=true  -> use saved JSON fixtures, NO live API calls (great for dev).
# MOCK_MODE=false -> hit SerpApi + Oxylabs for real (needs the keys above).
MOCK_MODE=true

# How many messages accumulate before the summarization node compresses them.
SUMMARY_TRIGGER=10

# Checkpointer DB file (SQLite). Conversations survive restarts via this file.
CHECKPOINT_DB=launchlens.sqlite
